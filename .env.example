# Example local env file for optional local testing only.
# Do not commit a real .env file.
# In GitHub Actions, add these same NAMES in Settings > Secrets and variables > Actions.

# Secret credential: the real value must only be stored in GitHub Secrets.
SHOPIFY_ADMIN_ACCESS_TOKEN=replace-with-shopify-admin-access-token

# Non-secret configuration values: these identify which shop/catalog to export.
# They are stored in GitHub Secrets too because the workflow reads all runtime config from secrets.
SHOPIFY_SHOP_DOMAIN=example-shop.myshopify.com
SHOPIFY_ADMIN_API_VERSION=2025-10
SHOPIFY_CATALOG_ID=1234567890
SHOPIFY_CATALOG_GID=gid://shopify/Catalog/1234567890
SHOPIFY_PUBLICATION_GID=gid://shopify/Publication/2345678901
SHOPIFY_PRICE_LIST_GID=gid://shopify/PriceList/3456789012
